# Our Place — Environment Variables
# Copy this file to .env.local and fill in real values.

# A strong random string used to sign JWTs (required in production)
JWT_SECRET=change-me-to-a-random-secret

# PostgreSQL connection string
# Local: postgresql://user:password@localhost:5432/ourplace
# Railway: provided automatically as DATABASE_URL
DATABASE_URL=postgresql://user:password@localhost:5432/ourplace
